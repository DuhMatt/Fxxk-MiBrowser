<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Default recommended scopes for LSPosed.
         Aggressive test profile: keep the known URL rewrite paths and
         XiaoAi screen-recognition participants, drop broad diagnostic scopes. -->
    <string-array name="xposed_scope">
        <!-- System Framework — catches all processes -->
        <item>android</item>
        <!-- Mi Share -->
        <item>com.miui.mishare.connectivity</item>
        <!-- Xiaomi App Store (download page redirects) -->
        <item>com.xiaomi.market</item>
        <!-- Xiaomi Browser itself -->
        <item>com.android.browser</item>
        <!-- Settings / Wi-Fi details page, including "Manage Xiaomi router" -->
        <item>com.android.settings</item>
        <!-- HyperAI Engine — clipboard URL recognition + screen recognition -->
        <item>com.xiaomi.aicr</item>
        <!-- Super XiaoAi / voice assistant — screen recognition URLs -->
        <item>com.miui.voiceassist</item>
        <!-- MIUI content catcher — participates in screen recognition -->
        <item>com.miui.contentcatcher</item>
        <!-- Xiaomi AI vision assistant — screen recognition on some HyperOS builds -->
        <item>com.xiaomi.aiasst.vision</item>
    </string-array>
</resources>
